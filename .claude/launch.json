{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "atlas-prototype",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["-y", "serve", "-l", "4173", "."],
      "port": 4173
    },
    {
      "name": "atlas-web",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "./atlas-mobile", "run", "web", "--", "--port", "8081"],
      "port": 8081,
      "autoPort": false
    },
    {
      "name": "atlas-web-dist",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["-y", "serve", "-l", "8082", "./atlas-mobile/dist"],
      "port": 8082
    }
  ]
}
