# Bu dosyayı .env olarak kopyala ve doldur. .env git'e girmez (.gitignore'da).
# ⚠️ SERVICE_ROLE anahtarı RLS'i tamamen bypass eder — asla mobil uygulamaya,
# istemci koduna veya repoya (bu örnek dosya hariç) koyma. Yalnız bu lokal
# scraper'ın kendi ortamında, elle çalıştırıldığında kullanılır.

SUPABASE_URL=https://zfhmvlxgrlmripwpawoh.supabase.co
# Supabase Dashboard > Settings > API > "service_role" (secret) anahtarını buraya yapıştır.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY
